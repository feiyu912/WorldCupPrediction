# Application
APP_ENV=development
LOG_LEVEL=INFO

# PostgreSQL (compose service: postgres)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=football
POSTGRES_USER=football
POSTGRES_PASSWORD=football

# Local DuckDB warehouse path
DUCKDB_PATH=./data/warehouse.duckdb

# Optional provider keys (NEVER hardcode in source; left blank in MVP)
EXTERNAL_ODDS_API_KEY=
EXTERNAL_FOOTBALLDATA_TOKEN=
EXTERNAL_ODDS_BASE_URL=
EXTERNAL_FOOTBALLDATA_BASE_URL=https://api.football-data.org

# Model registry location
MODEL_REGISTRY_DIR=./data/processed/models

# Deterministic random seed
GLOBAL_RANDOM_SEED=42
